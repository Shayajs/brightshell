APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Pour prod derrière NPM: APP_URL=https://brightshell.fr

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mariadb
# En dev Docker (docker-compose-shaya.dev) : alias réseau brightshell_db → conteneur brightshell_dev_db
DB_HOST=brightshell_db
DB_PORT=3306
DB_DATABASE=brightshell
DB_USERNAME=root
DB_PASSWORD=brightshell_secret

# Hors Docker, mettez DB_HOST=127.0.0.1 (ou votre hôte MariaDB)

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Pour partage de session multi-portails: SESSION_DOMAIN=.brightshell.fr (ou .brightshell.test en dev)
# Si null, BrightShell tente une déduction auto depuis BRIGHTSHELL_ROOT_DOMAIN / APP_URL.
# Après correctif cookies dupliqués, vous pouvez forcer un nouveau nom de cookie :
# SESSION_COOKIE=brightshell-portal-session

# Inscription publique /register (false = fermé ; premier admin : php artisan admin:init)
BRIGHTSHELL_REGISTRATION_OPEN=false

# Portail compte (URL absolue optionnelle; sinon account_host ou account.{root})
# Ex. prod: https://account.brightshell.fr
BRIGHTSHELL_ACCOUNT_URL=
BRIGHTSHELL_ACCOUNT_LOGIN_PATH=/login
# Host complet portail compte (ex. account.brightshell.fr) — vide = account.{root}
BRIGHTSHELL_ACCOUNT_HOST=
# Portail admin : host complet (ex. admin.brightshell.fr) — vide = admin.{root}
BRIGHTSHELL_ADMIN_HOST=
# Portails additionnels : hosts complets optionnels — vides = {sub}.{root}
BRIGHTSHELL_COLLABS_HOST=
BRIGHTSHELL_USERS_HOST=
BRIGHTSHELL_COURSES_HOST=
BRIGHTSHELL_SETTINGS_HOST=
# Documentation (ACL par rôle) — vide = docs.{root}
BRIGHTSHELL_DOCS_HOST=
# Hub portail (résumé des plateformes après connexion) — vide = home.{root}
BRIGHTSHELL_HOME_HOST=
# API lecture seule (GET /v1/entreprise) — vide = api.{BRIGHTSHELL_ROOT_DOMAIN ou hôte APP_URL}
BRIGHTSHELL_API_HOST=
# Webmail (Roundcube, etc.) — vide = mail.{BRIGHTSHELL_ROOT_DOMAIN ou hôte APP_URL} ; ou URL complète https://...
BRIGHTSHELL_MAIL_WEB_HOST=
# Domaine racine des sous-domaines (account.*, admin.*, courses.*, …). Vide = hôte de APP_URL sans www.
# Ex. prod explicite : brightshell.fr
BRIGHTSHELL_ROOT_DOMAIN=
# Liste des sous-domaines vitrine (séparés par des virgules), ex. www — account/admin/... ne doivent PAS y figurer
BRIGHTSHELL_VITRINE_SUBDOMAINS=www

# Identité vitrine (chemins sous public/, ex. img/favicon.png) — défauts = fichiers déjà dans public/img
# BRIGHTSHELL_BRAND_FAVICON=img/etoile_sans_fond_contours_fin.png
# BRIGHTSHELL_BRAND_SITE_LOGO=img/logo_sans_fond_contours_epais.webp
# Après connexion : URL absolue optionnelle (prioritaire sur la redirection par rôle le plus élevé)
BRIGHTSHELL_POST_LOGIN_URL=
# URLs absolues des portails (optionnel ; sinon https://{admin|collabs|users|courses|settings}.ROOT_DOMAIN/)
# BRIGHTSHELL_PORTAL_ADMIN_URL=
# BRIGHTSHELL_PORTAL_COLLABS_URL=
# BRIGHTSHELL_PORTAL_USERS_URL=
# BRIGHTSHELL_PORTAL_COURSES_URL=
# BRIGHTSHELL_PORTAL_SETTINGS_URL=
# BRIGHTSHELL_PORTAL_DOCS_URL=
# BRIGHTSHELL_PORTAL_HOME_URL=
# Chemin relatif si base_url renseigné (sinon ignoré quand POST_LOGIN_URL)
BRIGHTSHELL_POST_LOGIN_PATH=/

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
# Laisser vide, ou smtp / smtps — jamais « tls » (Symfony Mailer ; voir config/mail.php)
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

MAILBOX_SMTP_MAILER=smtp
MAILBOX_SMTP_HOST=127.0.0.1
MAILBOX_SMTP_PORT=587
MAILBOX_SMTP_USERNAME=null
MAILBOX_SMTP_PASSWORD=null
MAILBOX_SMTP_ENCRYPTION=tls
MAILBOX_FROM_ADDRESS="hello@example.com"
MAILBOX_FROM_NAME="${APP_NAME}"

MAILBOX_IMAP_HOST=127.0.0.1
MAILBOX_IMAP_PORT=993
MAILBOX_IMAP_USERNAME=null
MAILBOX_IMAP_PASSWORD=null
MAILBOX_IMAP_ENCRYPTION=ssl
MAILBOX_IMAP_VALIDATE_CERT=true
MAILBOX_IMAP_MAILBOX=INBOX

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
