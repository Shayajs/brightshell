{
  "key": "auth.password-reset",
  "name": "Changement de mot de passe",
  "category": "auth",
  "subject_template": "Reinitialisation de votre mot de passe",
  "variables": [
    "user_name",
    "action_url",
    "expires_at"
  ],
  "content": [
    {
      "type": "title",
      "text": "Modifier votre mot de passe"
    },
    {
      "type": "text",
      "text": "Bonjour {{user_name}}, une demande de reinitialisation a ete recue."
    },
    {
      "type": "button",
      "label": "Changer mon mot de passe",
      "url": "{{action_url}}"
    },
    {
      "type": "text",
      "text": "Ce lien expire le {{expires_at}}."
    }
  ]
}
