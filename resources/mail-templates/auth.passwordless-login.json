{
  "key": "auth.passwordless-login",
  "name": "Connexion sans mot de passe",
  "category": "auth",
  "subject_template": "Connexion securisee a Brightshell",
  "variables": [
    "user_name",
    "action_url",
    "code",
    "expires_at"
  ],
  "content": [
    {
      "type": "title",
      "text": "Connexion sans mot de passe"
    },
    {
      "type": "text",
      "text": "Bonjour {{user_name}}, utilisez ce lien ou ce code pour vous connecter."
    },
    {
      "type": "button",
      "label": "Se connecter",
      "url": "{{action_url}}"
    },
    {
      "type": "text",
      "text": "Code: {{code}} (expire le {{expires_at}})."
    }
  ]
}
